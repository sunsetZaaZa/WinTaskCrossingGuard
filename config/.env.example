# WinTaskCrossingGuard runtime settings
# Number of days to keep XML log files in the logs folder.
# Set to 0 to delete logs older than the current moment.
LOG_RETENTION=30

# Webhook / ChatOps notifications. Provider URLs are secrets; keep real values out of source control.
# Events can be: result,error,notification
WTCG_WEBHOOKS_ENABLED=true
WTCG_WEBHOOK_TIMEOUT_SECONDS=15
WTCG_WEBHOOK_FAIL_ON_ERROR=false

WTCG_WEBHOOK_TEAMS_ENABLED=false
WTCG_WEBHOOK_TEAMS_URL=
WTCG_WEBHOOK_TEAMS_EVENTS=result,error
WTCG_WEBHOOK_TEAMS_FAIL_ON_ERROR=false

WTCG_WEBHOOK_SLACK_ENABLED=false
WTCG_WEBHOOK_SLACK_URL=
WTCG_WEBHOOK_SLACK_EVENTS=result,error
WTCG_WEBHOOK_SLACK_FAIL_ON_ERROR=false

WTCG_WEBHOOK_DISCORD_ENABLED=false
WTCG_WEBHOOK_DISCORD_URL=
WTCG_WEBHOOK_DISCORD_EVENTS=result,error
WTCG_WEBHOOK_DISCORD_FAIL_ON_ERROR=false

# Telemetry export / Elastic-style payload builder. Workflow export reads JSONL events and writes export reports into the run folder.
# Keep API keys, bearer tokens, and collector secrets in private .env or a deployment secret store only.
WTCG_TELEMETRY_ENABLED=false
WTCG_TELEMETRY_EVENTS=result,error,notification,disable,re-enable,scheduled-reenable
WTCG_TELEMETRY_FAIL_ON_ERROR=false
WTCG_TELEMETRY_TIMEOUT_SECONDS=15
WTCG_TELEMETRY_BATCH_SIZE=100
WTCG_TELEMETRY_RETRY_COUNT=2
WTCG_TELEMETRY_RETRY_DELAY_SECONDS=2
WTCG_TELEMETRY_SINKS=elasticsearch

# Elasticsearch / OpenSearch-compatible bulk payload settings.
# WTCG_ELASTICSEARCH_API_KEY, USERNAME, and PASSWORD are secrets. Do not commit live values.
# For Elasticsearch data streams, set WTCG_ELASTICSEARCH_DATA_STREAM=true and use a data-stream name such as logs-wintaskcrossingguard-default.
WTCG_ELASTICSEARCH_ENABLED=false
WTCG_ELASTICSEARCH_URI=https://elastic.example.com:9200
WTCG_ELASTICSEARCH_INDEX=wintaskcrossingguard-events
WTCG_ELASTICSEARCH_DATA_STREAM=false
# Supported values: None, ApiKey, Bearer, Basic
WTCG_ELASTICSEARCH_AUTH_TYPE=None
WTCG_ELASTICSEARCH_API_KEY=
WTCG_ELASTICSEARCH_USERNAME=
WTCG_ELASTICSEARCH_PASSWORD=
WTCG_ELASTICSEARCH_ALLOW_INSECURE_TLS=false
# Generic HTTP telemetry sender. Used when WTCG_TELEMETRY_ENABLED=true and WTCG_TELEMETRY_SINKS includes genericHttp/http/generic.
# Header values and Authorization tokens are secrets. Reports include header names only.
WTCG_GENERIC_HTTP_ENABLED=false
WTCG_GENERIC_HTTP_URI=https://collector.example.com/events
WTCG_GENERIC_HTTP_METHOD=Post
WTCG_GENERIC_HTTP_FORMAT=ndjson
WTCG_GENERIC_HTTP_CONTENT_TYPE=application/x-ndjson
WTCG_GENERIC_HTTP_HEADERS=X-WTCG-Source=WinTaskCrossingGuard
WTCG_GENERIC_HTTP_AUTH_HEADER_NAME=Authorization
WTCG_GENERIC_HTTP_AUTH_HEADER_VALUE=
WTCG_GENERIC_HTTP_ALLOW_INSECURE_TLS=false


# Stage 6 telemetry adapters. Values below are examples; tokens and URLs are secrets.
# Enable by adding sink names to WTCG_TELEMETRY_SINKS, for example:
# WTCG_TELEMETRY_SINKS=datadog,splunkHec,azureMonitor,logstash

# Datadog Logs HTTP intake. WTCG_DATADOG_API_KEY is a secret.
WTCG_DATADOG_ENABLED=false
WTCG_DATADOG_URI=https://http-intake.logs.datadoghq.com/api/v2/logs
WTCG_DATADOG_API_KEY=
WTCG_DATADOG_SERVICE=wintaskcrossingguard
WTCG_DATADOG_SOURCE=powershell
WTCG_DATADOG_TAGS=tool:wintaskcrossingguard,env:example
WTCG_DATADOG_ALLOW_INSECURE_TLS=false

# Splunk HTTP Event Collector. WTCG_SPLUNK_HEC_TOKEN is a secret.
WTCG_SPLUNK_HEC_ENABLED=false
WTCG_SPLUNK_HEC_URI=https://splunk.example.com:8088/services/collector
WTCG_SPLUNK_HEC_TOKEN=
WTCG_SPLUNK_HEC_INDEX=
WTCG_SPLUNK_HEC_SOURCE=WinTaskCrossingGuard
WTCG_SPLUNK_HEC_SOURCETYPE=_json
WTCG_SPLUNK_HEC_ALLOW_INSECURE_TLS=false

# Azure Monitor Logs Ingestion API / Microsoft Sentinel custom table.
# WTCG_AZURE_MONITOR_BEARER_TOKEN is a secret and should come from managed identity or secret storage.
WTCG_AZURE_MONITOR_ENABLED=false
WTCG_AZURE_MONITOR_URI=
WTCG_AZURE_MONITOR_ENDPOINT=https://dce-example.eastus-1.ingest.monitor.azure.com
WTCG_AZURE_MONITOR_DCR_IMMUTABLE_ID=dcr-00000000000000000000000000000000
WTCG_AZURE_MONITOR_STREAM_NAME=Custom-WinTaskCrossingGuard_CL
WTCG_AZURE_MONITOR_API_VERSION=2023-01-01
WTCG_AZURE_MONITOR_BEARER_TOKEN=
WTCG_AZURE_MONITOR_ALLOW_INSECURE_TLS=false

# Logstash HTTP input. Use ndjson with an http input + json_lines codec, or jsonArray with a json codec.
WTCG_LOGSTASH_ENABLED=false
WTCG_LOGSTASH_URI=https://logstash.example.com:8080/wintaskcrossingguard
WTCG_LOGSTASH_FORMAT=ndjson
WTCG_LOGSTASH_CONTENT_TYPE=application/x-ndjson
WTCG_LOGSTASH_HEADERS=X-WTCG-Source=WinTaskCrossingGuard
WTCG_LOGSTASH_AUTH_HEADER_NAME=
WTCG_LOGSTASH_AUTH_HEADER_VALUE=
WTCG_LOGSTASH_ALLOW_INSECURE_TLS=false
